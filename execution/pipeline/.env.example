# Copy to .env and fill in API keys.
# No quotes, brackets, or trailing whitespace.

# TheGraph (Phase B trade-flow attribution)
# https://thegraph.com/studio → "API Keys". Free tier: 100k queries/month.
THEGRAPH_API_KEY=your-32-char-key-here

# Etherscan V2 multichain (Phase 2 nft_queue valuation, Phase 3 lag, Phase 4 DEX attribution)
# https://etherscan.io/myapikey. Free tier: 5 calls/sec, 100k/day. One key works
# across all supported chains via the V2 chainid param (chainid=1 Mainnet, =10 OP).
ETHERSCAN_API_KEY=your-key-here
